<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AIApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/wa_bg_dark</item>
        <item name="colorPrimaryVariant">@color/wa_bg_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/wa_accent</item>
        <item name="colorSecondaryVariant">@color/wa_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/wa_bg_dark</item>
        <!-- Navigation bar color. -->
        <item name="android:navigationBarColor">@color/wa_bg_dark</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/wa_bg_dark</item>
    </style>
</resources>
